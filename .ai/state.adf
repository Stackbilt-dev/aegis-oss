  DEPLOY_COMMANDS: >
    # Authenticate wrangler (from project root):
    export $(grep CLOUDFLARE_API_TOKEN .dev.vars | tr -d '\r' | xargs)

    # Deploy Worker:
    cd web && npx wrangler deploy

    # Run D1 migration (if schema changed):
    npx wrangler d1 execute aegis-web --remote --file=schema.sql

    # Set a secret:
    npx wrangler secret put SECRET_NAME --name aegis-web

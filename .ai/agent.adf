  bizops:
    - 29 tools: set_context, get_context, list_orgs, get_org, create_org, update_org, rapid_intake,
      list_compliance, create_compliance, update_compliance, delete_compliance, upcoming_deadlines,
      list_documents, create_document, update_document, delete_document, doc_gaps,
